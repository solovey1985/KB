{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=QueueProcessorDb;Trusted_Connection=true;TrustServerCertificate=true;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "FunctionSettings": {
    "MaxRetries": 3,
    "ProcessingTimeout": 30000,
    "BatchSize": 10
  },
  "DatabaseSettings": {
    "CommandTimeout": 300,
    "EnableDetailedErrors": false
  },
  "ApplicationInsights": {
    "InstrumentationKey": ""
  }
}
